# Foundry deploy env. Copy to .env and fill in.

# Deployer key (will be admin until handover)
PRIVATE_KEY=0x

# Final admin (multisig on mainnet). Defaults to deployer if unset.
ADMIN_ADDRESS=

# RPCs (used by foundry rpc_endpoints in foundry.toml)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Etherscan / Basescan for contract verification (--verify)
BASESCAN_API_KEY=

# USDC override (defaults to canonical Base USDC for the active chainId)
USDC_ADDRESS=

# Optional roles granted in Deploy.s.sol when admin == deployer
VERIFIER_ADDRESS=
BRIDGE_ADDRESS=
