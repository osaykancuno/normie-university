# =============================================================================
# SKILLAI — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# NETWORK
# ---------------------------------------------------------------------------
# "testnet" uses Base Sepolia | "mainnet" uses Base Mainnet
NEXT_PUBLIC_NETWORK=testnet

# ---------------------------------------------------------------------------
# RPC ENDPOINTS (get a free key at https://www.alchemy.com or https://infura.io)
# ---------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Also expose the testnet RPC to the frontend
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ---------------------------------------------------------------------------
# WALLET / DEPLOY
# ---------------------------------------------------------------------------
# Private key of the deployer wallet (never share this!)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ---------------------------------------------------------------------------
# BASESCAN API KEY (for contract verification)
# Get it free at https://basescan.org/myapikey
# ---------------------------------------------------------------------------
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ---------------------------------------------------------------------------
# WALLETCONNECT (for RainbowKit multi-wallet support)
# Get a free projectId at https://cloud.walletconnect.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=c085bed085b98c624c9a5ef64c33832f

# ---------------------------------------------------------------------------
# PINATA / IPFS (for skill module storage)
# Get free keys at https://www.pinata.cloud
# ---------------------------------------------------------------------------
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ---------------------------------------------------------------------------
# VERIFIER SIGNING KEY (for off-chain skill verification)
# This is the private key of the authorized verifier wallet
# ---------------------------------------------------------------------------
VERIFIER_PRIVATE_KEY=0xYOUR_VERIFIER_PRIVATE_KEY
NEXT_PUBLIC_VERIFIER_ADDRESS=0xYOUR_VERIFIER_PUBLIC_ADDRESS
